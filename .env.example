# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_NAME=Med4U
API_PREFIX=api
FRONTEND_URL=http://localhost:3001

# ─── Database (PostgreSQL) ───────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=med4u_user
DB_PASSWORD=med4u_password
DB_NAME=med4u_db
DB_SSL=false
DB_SYNC=true
DB_LOGGING=true

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=3600

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=this-is-a-32-char-dev-secret-key!
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=another-32-char-dev-secret-key!!
JWT_REFRESH_EXPIRES_IN=7d

# ─── Cloudinary ──────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="Med4U <noreply@med4u.com>"

# ─── SMS / Twilio ─────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ─── Rate Limiting ────────────────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100
AUTH_THROTTLE_TTL=60
AUTH_THROTTLE_LIMIT=5

# ─── Swagger ─────────────────────────────────────────────────────────────────
SWAGGER_ENABLED=true
SWAGGER_PATH=api/docs

# ─── File Upload ─────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,application/pdf

# ─── WebSocket ───────────────────────────────────────────────────────────────
WS_CORS_ORIGIN=http://localhost:3001

# ─── Encryption ──────────────────────────────────────────────────────────────
ENCRYPTION_KEY=32-char-encryption-key-change-me!

# ─── Health / Monitoring ─────────────────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=debug
